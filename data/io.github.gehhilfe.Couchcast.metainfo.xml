<component type="desktop-application">
  <id>io.github.gehhilfe.Couchcast</id>

  <name>Couchcast</name>
  <summary>Watch an HDMI capture device and control it with a gamepad</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT OR Apache-2.0</project_license>

  <developer id="io.github.gehhilfe">
    <name>The Couchcast Authors</name>
  </developer>

  <description>
    <p>
      Couchcast turns a Fire TV, Android TV box, or other streaming stick captured
      over HDMI into what feels like a native app on your Linux PC or Steam Deck.
      It shows the live low-latency video and audio full-screen and forwards your
      controller and keyboard input back to the device, so you can navigate and
      play from the couch with just a gamepad.
    </p>
    <p>Features:</p>
    <ul>
      <li>Low-latency full-screen video from any V4L2 HDMI capture device</li>
      <li>Audio passthrough kept in sync with the video</li>
      <li>Controller input forwarded to the device (Fire TV / Android TV over ADB)</li>
      <li>Editable button mapping</li>
      <li>Fully controller-navigable — no mouse required, built for SteamOS Gaming Mode</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.gehhilfe.Couchcast.desktop</launchable>

